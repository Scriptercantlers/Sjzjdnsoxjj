local function update_rand_label()
    local h = Options.rand_Head and Options.rand_Head.Value or 33
    local b = Options.rand_Body and Options.rand_Body.Value or 33
    local m = Options.rand_Miss and Options.rand_Miss.Value or 34
    local total = h + b + m
    if total == 0 then m = 1; total = 1 end
    local hp = math.floor((h / total) * 100)
    local bp = math.floor((b / total) * 100)
    local mp = 100 - hp - bp
    if cheat.randLabel then cheat.randLabel:SetText(string.format("%d%% Голова - %d%% Тело - %d%% Промах", hp, bp, mp)) end
    return hp, bp, mp
end

