local function applyWorldESP(model)
    if typeof(model) ~= "Instance" or not model:IsA("Model") then return end

    if model.Name == "Model" and #model:GetChildren() == 2 and model:FindFirstChild("Part") then
        local p1 = model:FindFirstChild("Part")
        if p1:IsA("BasePart") and p1.Size.Y < 3 and p1.Size.X < 3 and p1.Size.Z < 3 then
            local id = "Bag_" .. model:GetDebugId()
            local hl = ChamStorage:FindFirstChild(id) or Instance.new("Highlight", ChamStorage)
            hl.Name = id; hl.Adornee = model; hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            activeBags[model] = { highlight = hl, drawings = createDrawings(), part = p1, name = "мешок" }
        end
    end
    
    if not model.Name:find("InteriorContainer") and not model:FindFirstChild("State") then
        local children = {}
        for _, child in pairs(model:GetChildren()) do children[child.Name] = true end
        local isCrate, memeName = false, ""

        if children['Bottom'] and children['Top'] then isCrate = true; memeName = "йощек абични"
        elseif children['box'] and children['trash'] then isCrate = true; memeName = "мусор"
        elseif children['Dispenser'] and children['Machine'] then isCrate = true; memeName = "автомат с хилкай"
        elseif children['Body'] and children['Wheel'] then isCrate = true; memeName = "телега с лутом"
        elseif model.Name == "CashRegister" or model.Name == "Register" then isCrate = true; memeName = "каса"
        elseif model.Name == "Safe" then isCrate = true; memeName = "сейф ебать" end

        if model:FindFirstChild("Humanoid") then isCrate = false end

        if isCrate then
            local id = "Crate_" .. model:GetDebugId()
            local hl = ChamStorage:FindFirstChild(id) or Instance.new("Highlight", ChamStorage)
            hl.Name = id; hl.Adornee = model; hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            activeCrates[model] = { highlight = hl, drawings = createDrawings(), part = model.PrimaryPart or model:FindFirstChildWhichIsA("BasePart"), name = memeName }
        end
    end
end

