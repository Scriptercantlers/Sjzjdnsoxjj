local BulletTrailEnabled = false
local BulletTrailColor = Color3.fromRGB(255, 255, 255)
local BulletTrailThickness = 0.2
local BulletTrailLength = 10
local BulletTrailLifetime = 0.1

local function createBulletTrail(bullet)
    local trailData = { bullet = bullet, points = {} }
    local connection
    connection = RunService.RenderStepped:Connect(function()
        if not BulletTrailEnabled then return end
        if not bullet or not bullet.Parent then
            connection:Disconnect()
            return
        end
        local pos = bullet.Position or bullet.CFrame.Position
        table.insert(trailData.points, 1, pos)
        if #trailData.points > BulletTrailLength then
            table.remove(trailData.points)
        end
        for i = 1, #trailData.points - 1 do
            local p1 = trailData.points[i]
            local p2 = trailData.points[i + 1]
            local part = Instance.new("Part")
            part.Anchored = true
            part.CanCollide = false
            part.Size = Vector3.new(BulletTrailThickness, BulletTrailThickness, (p1 - p2).Magnitude)
            part.CFrame = CFrame.new(p1, p2) * CFrame.new(0, 0, -part.Size.Z / 2)
            part.Color = BulletTrailColor
            part.Material = Enum.Material.ForceField
            part.Parent = workspace
            game:GetService("Debris"):AddItem(part, BulletTrailLifetime)
        end
    end)
end

workspace.DescendantAdded:Connect(function(desc)
    if desc.Name == "Bullet" and not desc:IsDescendantOf(ReplicatedStorage) and BulletTrailEnabled then
