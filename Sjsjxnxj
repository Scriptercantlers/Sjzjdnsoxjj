local function createTextDrawing(textStr, color)
    local text = Drawing.new("Text")
    text.Text = textStr
    text.Size = 16
    text.Center = true
    text.Outline = true
    text.OutlineColor = Color3.new(0, 0, 0)
    text.Color = color
    text.Visible = false
    return text
end

local function getWeaponName(model)
    local handModel = model:FindFirstChild("HandModel")
    if not handModel then return "None" end
    local bestMatch = nil
    local maxParts = 0
    for wName, wParts in pairs(WeaponPartsMapping) do
        local foundParts = 0
        for _, partName in ipairs(wParts) do
            if handModel:FindFirstChild(partName, true) then
                foundParts = foundParts + 1
            end
        end
        if foundParts > maxParts then
            maxParts = foundParts
            bestMatch = wName
        end
    end
    return bestMatch or "None"
end

local function setupWeaponESP(model)
    if WeaponESP_Drawings[model] then return end
    local head = model:FindFirstChild("Head")
    local torso = model:FindFirstChild("Torso") or model:FindFirstChild("UpperTorso") or model:FindFirstChild("LowerTorso")
    if not head or not torso then return end

    WeaponESP_Drawings[model] = { 
        text = createTextDrawing("None", Color3.fromRGB(255, 255, 255)), 
        head = head, 
        torso = torso 
    }

    model.Destroying:Connect(function()
        if WeaponESP_Drawings[model] then
            WeaponESP_Drawings[model].text:Remove()
            WeaponESP_Drawings[model] = nil
        end
    end)
end

local function setupItemESP(model)
    if ItemESP_Drawings[model] then return end
    local union = model:FindFirstChild("Union")
    local display = model:FindFirstChild("Display")
    local part = model:FindFirstChild("Part")
    
    local targetPart = union or display or part
    if not targetPart then return end

    ItemESP_Drawings[model] = {
        drawing = createTextDrawing("Item", Color3.new(1, 1, 0)), 
        part = targetPart
    }
end

local function scanItems()
    if not ItemESP_Enabled then return end
    for _, v in ipairs(workspace:GetChildren()) do
        if v:IsA("Model") then setupItemESP(v) end
    end
end

local function clearItems()
    for _, data in pairs(ItemESP_Drawings) do
        data.drawing:Remove()
    end
    ItemESP_Drawings = {}
end

