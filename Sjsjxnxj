local HandModelsFolder = ReplicatedStorage:WaitForChild("HandModels")
local WeaponParts = {}
local WeaponOriginalMats = {}

local function scanWeaponParts(model)
    local parts = {}
    local mats = {}
    local function scan(parent)
        if parent:IsA("BasePart") then
            table.insert(parts, parent)
            if not mats[parent] then mats[parent] = parent.Material end
        end
        for _, child in ipairs(parent:GetChildren()) do scan(child) end
    end
    scan(model)
    return parts, mats
end

local function updateWeaponParts()
    WeaponParts = {}
    for _, model in ipairs(HandModelsFolder:GetChildren()) do
        local parts, mats = scanWeaponParts(model)
        WeaponParts[model] = parts
        for part, mat in pairs(mats) do
            WeaponOriginalMats[part] = mat
        end
    end
end

local function applyWeaponMaterial(matName)
    if matName == "Default" then
        for _, parts in pairs(WeaponParts) do
            for _, part in ipairs(parts) do
                if part and part.Parent then
                    part.Material = WeaponOriginalMats[part] or Enum.Material.Plastic
                end
            end
        end
    else
        local success, matEnum = pcall(function() return Enum.Material[matName] end)
        if success and matEnum then
            for _, parts in pairs(WeaponParts) do
                for _, part in ipairs(parts) do
                    if part and part.Parent then part.Material = matEnum end
                end
            end
        else
            for _, parts in pairs(WeaponParts) do
                for _, part in ipairs(parts) do
                    if part and part.Parent then
                        pcall(function() part.MaterialVariant = matName end)
                    end
                end
            end
        end
    end
end

local function applyWeaponColor(color)
    for _, parts in pairs(WeaponParts) do
        for _, part in ipairs(parts) do
