local function create_esp(model)
    if model == LocalPlayer.Character then return end
    
    task.spawn(function()
        task.wait(0.5) -- Ждем пока игрок полностью прогрузится
        if not model or not model.Parent then return end
        
        applyChams(model)
        
        local head = model:FindFirstChild("Head")
        local hrp = model:FindFirstChild("HumanoidRootPart")
        local humanoid = model:FindFirstChild("Humanoid") or model:FindFirstChildWhichIsA("Humanoid")

        if head and hrp then
            local imgGui = Instance.new("BillboardGui", head)
            imgGui.Name = "PlayerMemeImage"
            imgGui.Size = UDim2.new(4, 0, 4, 0)
            imgGui.AlwaysOnTop = true
            imgGui.StudsOffset = Vector3.new(0, 3.5, 0)
            local imgLabel = Instance.new("ImageLabel", imgGui)
            imgLabel.Size = UDim2.new(1, 0, 1, 0)
            imgLabel.BackgroundTransparency = 1
            imgLabel.Image = "rbxassetid://114132252876567"

            local obj = {
                box = cheat.utility.new_drawing("Square", { Filled = false, Thickness = 1, Visible = false }),
                name = cheat.utility.new_drawing("Text", { Center = true, Visible = false, Size = 13, Outline = true, Font = 2 }),
                dist = cheat.utility.new_drawing("Text", { Center = true, Visible = false, Size = 13, Outline = true, Font = 2 }),
                team_text = cheat.utility.new_drawing("Text", { Center = true, Visible = false, Text = "ТИМЕЙТ!!", Color = Color3.fromRGB(0, 255, 0), Font = 2, Size = 13, Outline = true })
            }

            local connection
            connection = RunService.RenderStepped:Connect(function()
                -- ПРОВЕРКА НА СМЕРТЬ ИЛИ ВЫХОД ИГРОКА (УДАЛЕНИЕ ПРИЗРАКОВ)
                if not model or not model.Parent or not head or not head.Parent or (humanoid and humanoid.Health <= 0) then
                    for _, o in pairs(obj) do 
                        o.Visible = false
                        o:Remove() -- Полностью стираем рисунки из памяти
                    end
                    if imgGui then imgGui:Destroy() end
                    local highlight = model:FindFirstChild("UniversalCham")
                    if highlight then highlight:Destroy() end
                    
                    if connection then connection:Disconnect() end
                    return
                end

                -- ПРОВЕРКА ДИСТАНЦИИ (МАКСИМУМ 1200)
                local distance = (Camera.CFrame.Position - head.Position).Magnitude
                local inRange = distance <= 1200

                if EspLibrary.settings.hb_enabled then
                    head.Size = Vector3.new(2 * EspLibrary.settings.hb_size, 2 * EspLibrary.settings.hb_size, 2 * EspLibrary.settings.hb_size)
                    head.Transparency = EspLibrary.settings.hb_transparency
                    head.CanCollide = EspLibrary.settings.hb_collision
                else
                    head.Size = Vector3.new(2, 1, 1)
                    head.Transparency = 0
                    head.CanCollide = true
                end
                
                if imgGui then imgGui.Enabled = EspLibrary.settings.enabled and EspLibrary.settings.image_en and inRange end

                local highlight = model:FindFirstChild("UniversalCham")
                if highlight then
                    highlight.Enabled = EspLibrary.settings.chams_enabled and inRange
                    highlight.FillColor = EspLibrary.settings.chams_color
                    highlight.FillTransparency = 1 - EspLibrary.settings.chams_opacity
                end

                if not EspLibrary.settings.enabled or not inRange then 
                    for _, o in pairs(obj) do o.Visible = false end
                    return 
                end

                local screenPos, onScreen = Camera:WorldToViewportPoint(head.Position)
                if onScreen then
                    local customName = assignedNames[model] or model.Name
                    local is_team = team_feature_enabled and Teammates[customName]

                    obj.box.Visible = EspLibrary.settings.box
                    obj.box.Size = Vector2.new(2000 / screenPos.Z, 2500 / screenPos.Z)
                    obj.box.Position = Vector2.new(screenPos.X - obj.box.Size.X / 2, screenPos.Y - obj.box.Size.Y / 2)
                    obj.box.Color = EspLibrary.settings.box_color[1]
                    
                    obj.name.Visible = EspLibrary.settings.realname
                    obj.name.Text = customName
                    obj.name.Position = obj.box.Position - Vector2.new(0, 15)
                    obj.name.Color = EspLibrary.settings.realname_color[1]
                    
                    obj.dist.Visible = EspLibrary.settings.dist
                    obj.dist.Text = math.floor(distance) .. "m"
                    obj.dist.Position = obj.box.Position + Vector2.new(obj.box.Size.X / 2, obj.box.Size.Y + 2)
                    obj.dist.Color = EspLibrary.settings.dist_color[1]

                    if is_team then
                        obj.team_text.Visible = true
                        obj.team_text.Position = obj.name.Visible and (obj.name.Position - Vector2.new(0, 15)) or (obj.box.Position - Vector2.new(0, 15))
                        obj.team_text.Transparency = 0.4 + math.abs(math.sin(tick() * 6)) * 0.6
                    else
                        obj.team_text.Visible = false
                    end
                else
                    for _, o in pairs(obj) do o.Visible = false end
                end
            end)
        end
    end)
end

