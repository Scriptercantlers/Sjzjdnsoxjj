FC_UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if keyMap[input.KeyCode] then
        activeKeys[input.KeyCode] = true
    end
end)

FC_UserInputService.InputEnded:Connect(function(input)
    if keyMap[input.KeyCode] then
        activeKeys[input.KeyCode] = false
    end
end)

FC_UserInputService.InputChanged:Connect(function(input, gameProcessed)
    if gameProcessed then return end 
    if FreeCamEnabled and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        camYaw = camYaw - input.Delta.X * 0.005
        camPitch = math.clamp(camPitch - input.Delta.Y * 0.005, -PITCH_LIMIT, PITCH_LIMIT)
    end
end)

FC_RunService.RenderStepped:Connect(function(dt)
    if FreeCamEnabled then
        local moveDir = Vector3.zero
        
        for key, dir in pairs(keyMap) do
            if activeKeys[key] then
                moveDir = moveDir + dir
            end
        end
        
        if isForwardPressed then
            moveDir = moveDir + Vector3.new(0, 0, -1)
        end
        
        if MobileControls then
            local moveVector = MobileControls:GetMoveVector()
            if moveVector.Magnitude > 0 then
                moveDir = moveDir + Vector3.new(moveVector.X, 0, moveVector.Z)
            end
        end
        
        local camRotation = CFrame.Angles(0, camYaw, 0) * CFrame.Angles(camPitch, 0, 0)
        
        if moveDir.Magnitude > 0 then
            moveDir = camRotation:VectorToWorldSpace(moveDir).Unit
            camPos = camPos + moveDir * FreeCamSpeed * dt
        end
        
        FC_Camera.CFrame = CFrame.new(camPos) * camRotation
    end
end)

