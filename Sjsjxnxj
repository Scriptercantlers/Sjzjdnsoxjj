local function ToggleFreeCam(state)
    if state ~= nil then
        FreeCamEnabled = state
    else
        FreeCamEnabled = not FreeCamEnabled
    end
    
    if FreeCamEnabled then
        toggleBtn.TextColor3 = Color3.fromRGB(50, 255, 50)
        forwardBtn.Visible = true
        
        camPos = FC_Camera.CFrame.Position
        local look = FC_Camera.CFrame.LookVector
        camYaw = math.atan2(-look.X, -look.Z)
        camPitch = math.asin(look.Y)
        
        FC_Camera.CameraType = Enum.CameraType.Scriptable
        
        if FC_LocalPlayer.Character and FC_LocalPlayer.Character:FindFirstChild("Humanoid") then
            savedWalkSpeed = FC_LocalPlayer.Character.Humanoid.WalkSpeed
            savedJumpPower = FC_LocalPlayer.Character.Humanoid.JumpPower
            FC_LocalPlayer.Character.Humanoid.WalkSpeed = 0
            FC_LocalPlayer.Character.Humanoid.JumpPower = 0
        end
    else
        toggleBtn.TextColor3 = Color3.fromRGB(255, 50, 50)
        forwardBtn.Visible = false
        isForwardPressed = false
        
        FC_Camera.CameraType = Enum.CameraType.Custom
        
        if FC_LocalPlayer.Character and FC_LocalPlayer.Character:FindFirstChild("Humanoid") then
            FC_LocalPlayer.Character.Humanoid.WalkSpeed = savedWalkSpeed
            FC_LocalPlayer.Character.Humanoid.JumpPower = savedJumpPower
        end
    end
end

